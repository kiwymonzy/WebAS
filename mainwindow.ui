                      <property name="styleSheet">
                       <string notr="true">/* COLOR 
background-color: #0A92A9; //blue
background-color: #D7943D; //yellow
background-color: #DB3511;//red
border-radius: 30px;
*/
QCalendarWidget QToolButton
{
	height:50px;
	width:150px;
	color:black;
	font-size:30px;
	icon-size:50px 50px;
	background-color: #D7943D;
}
QCalendarWidget QWidget#qt_calendar_navigationbar
{
	background-color:rgb(52,50,64);
}

/* MenuBar Code */

QCalendarWidget QMenu
{
	width:150px;
	left:20px;
	color:black;
	font-size:18px;
	background-color:#D7943D;
}

/* SpinBox Code */

QCalendarWidget QSpinBox
{
	width:150px;
	height:60px;
	font-size:24px;
	color:black;
	background-color:#D7943D
}
QCalendarWidget QSpinBox::up-button
{
	subcontrol-origin: border;
	subcontrol-position:left;
	width:65px;
	height:60px;
}
QCalendarWidget QSpinBox::down-button
{
	subcontrol-origin: border;
	subcontrol-position:right;
	width:65px;
	height:60px;
}

/* Calendar View Code */
QCalendarWidget QWidget
{
	alternate-background-color:rgb(150,40,34);
}
QCalendarWidget QAbstractItemView:enabled
{
	font-size:24px;
	color:white;
	background-color:rgb(52,50,64);	
	selection-background-color:rgb(52,50,64);
	selection-color:#0A92A9;
}
QCalendarWidget QAbstractItemView:disabled
{
	color:rgb(100,100,100);
}
QCalendarWidget QToolTip 
{ 
	color: white; 
	font-size:40px;
	background-color: rgb(150,40,34); 
	border: 1px solid black; 
}

</string>
