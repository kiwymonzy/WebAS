   <property name="styleSheet">
    <string notr="true">*{
color:#000;
border:none;
}
#pushButton{
background-color: #0A92A9;
}

#leftMenu QPushButton  {
color: #000;
padding: 10px;	
text-align: left;
background-color: #0A92A9;
border-bottom: 1px solid #282c34;
}

#leftMenu .QPushButton:pressed {	
	background-color: #1F9CF8;
	color: #000;
}

/* /////////////////////////////////////////////////////////////////////////////////////////////////
BgApp */
#BgApp{	
	background-color: #282c34;
	border: 1px solid rgb(44, 49, 58);
}
#leftMenu{
background-color: #0A92A9;
/*
background-color: qlineargradient(spread:pad, x1:0, y1:0.511364, x2:1, y2:0.523, stop:0 #1F9CF8, stop:1 #8BB8C7);
*/
border-radius: 20px;
}

/* Bottom Bar */
#bottomBar QWidget{ 
background-color: #2B3038;
 }
#bottomBar QLabel { 
font-size: 11px; 
color: rgb(113, 126, 149); 
padding-left: 10px; 
padding-right: 10px; 
padding-bottom: 2px; 
}

/* /////////////////////////////////////////////////////////////////////////////////////////////////
Button */
#mainBody QPushButton {
	border: 2px solid rgb(52, 59, 72);
	border-radius: 5px;	
	background-color: rgb(52, 59, 72);
}

#mainBody QPushButton:hover {
	background-color: rgb(57, 65, 80);
	border: 2px solid rgb(61, 70, 86);
}
#mainBody QPushButton:pressed {	
	background-color: rgb(35, 40, 49);
	border: 2px solid rgb(43, 50, 61);
}

#searchFrame{
border-radius: 10px;
border:2px solid #1F9CF8;
}


#appHeaderDay{
color: #D7943D;
}
#appHeaderDate{
color: #0A92A9;
}

#profileCont{
background-color: #8BB8C7;
border-radius: 20px;
}

#profileCont QPushButton{
color:#fff;
background-color: #CB4D20;
border-radius: 20px;
padding: 5px
}

</string>
