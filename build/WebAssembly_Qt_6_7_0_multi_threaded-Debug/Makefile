	@if not exist $(INSTALL_ROOT:@msyshack@%=%)\opt\WebAss\bin mkdir $(INSTALL_ROOT:@msyshack@%=%)\opt\WebAss\bin & if not exist $(INSTALL_ROOT:@msyshack@%=%)\opt\WebAss\bin exit 1
	$(QINSTALL_PROGRAM) $(QMAKE_TARGET) $(INSTALL_ROOT:@msyshack@%=%)\opt\WebAss\bin\$(QMAKE_TARGET)

